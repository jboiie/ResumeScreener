# ══════════════════════════════════════════════════════════════
#  Resume Screener — Environment Configuration
#
#  HOW TO USE:
#    1. Copy this file:   cp .env.example .env
#    2. Fill in your values below
#    3. Never commit .env to git (it contains secrets)
# ══════════════════════════════════════════════════════════════


# ── LLM Reranker ───────────────────────────────────────────────
#
# Which AI provider to use for reranking candidates.
# Options: "groq" (recommended — faster, free tier) or "gemini"
LLM_PROVIDER=groq

# Groq API Key
# Sign up free at: https://console.groq.com
# Free tier: 30 req/min, 14,400 req/day — plenty for HR use
GROQ_API_KEY=

# Groq model to use (default is fast + accurate, do not change unless needed)
GROQ_MODEL=llama-3.1-8b-instant

# Gemini API Key — only fill this if you set LLM_PROVIDER=gemini above
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use (only if LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-1.5-flash


# ── API Security ───────────────────────────────────────────────
#
# A secret key your ERP system must send in the X-API-Key header.
# Generate a secure key using:   openssl rand -hex 32
# Or any strong random string (32+ characters recommended)
API_KEY=


# ── CV Storage ─────────────────────────────────────────────────
#
# Full path to the folder containing your CV/resume files.
# The indexer will scan this folder recursively for .pdf and .docx files.
#
# Examples:
#   Windows:  CV_FOLDER_PATH=C:/HR/Resumes
#   Linux:    CV_FOLDER_PATH=/mnt/shared/resumes
#   Default:  CV_FOLDER_PATH=./cvs   (puts CVs in the project's cvs/ folder)
CV_FOLDER_PATH=./cvs


# ── Qdrant Vector Database ─────────────────────────────────────
#
# Leave these as default unless you changed the docker-compose.yml ports.
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=resumes


# ── Screening Defaults ─────────────────────────────────────────
#
# Default number of candidates to return per screening request.
# Can be overridden per-request via the "top_k" field in the API body.
DEFAULT_TOP_K=10

# How many candidates to fetch from the vector DB before LLM reranking.
# Higher = more accurate but slightly slower. Recommended range: 20–50.
RETRIEVAL_TOP_N=30

# Embedding model — do not change unless you know what you're doing.
# Changing this requires re-indexing all CVs from scratch.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OCR for scanned / image-only PDFs.
# When true (default), the indexer uses Tesseract to extract text from
# PDFs that have no text layer (e.g. scanned paper CVs, photo PDFs).
# Set to false if all your CVs are digital/text-based — slightly faster indexing.
# Requires: tesseract-ocr and poppler-utils (pre-installed in Docker image).
ENABLE_OCR=true


# ── Server ─────────────────────────────────────────────────────
#
# Port the API will be accessible on. http://your-server-ip:8000
API_PORT=8000

# Log level: DEBUG (verbose) | INFO (normal) | WARNING | ERROR
LOG_LEVEL=INFO

# ── CORS ───────────────────────────────────────────────────────
#
# Which origins (domains) can call this API from a browser.
# Use * to allow all, or comma-separate specific domains:
#   ALLOWED_ORIGINS=https://erp.yourcompany.com,https://hr.yourcompany.com
ALLOWED_ORIGINS=https://erp.yourcompany.com
